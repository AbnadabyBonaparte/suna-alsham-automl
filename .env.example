# ═══════════════════════════════════════════════════════════════
# ALSHAM QUANTUM - Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha com seus valores

# ─────────────────────────────────────────────────────────────
# SUPABASE (OBRIGATÓRIO - Database + Auth)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# Server-only. Usado pelo motor de agentes e pelo webhook do Stripe (ignora RLS).
# NUNCA exponha no client / NUNCA prefixe com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ─────────────────────────────────────────────────────────────
# AI PROVIDERS (Para funcionalidades de IA)
# ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY: usado pelos 10 agentes reais (task-executor, gpt-4o-mini)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY: usado pelo chat do ORION (claude-sonnet-4-5)
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=

# ─────────────────────────────────────────────────────────────
# OAUTH PROVIDERS (Opcional - Social Login)
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# INTEGRATIONS (Opcional)
# ─────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
RESEND_API_KEY=

# ── Stripe (billing) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
# Price IDs de cada plano (Stripe Dashboard → Products → Prices)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_...

# ─────────────────────────────────────────────────────────────
# NOTIFICATIONS (Opcional)
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SLACK_TOKEN=

# ─────────────────────────────────────────────────────────────
# MONITORING (Opcional)
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────
# SISTEMA (Configurações gerais)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
